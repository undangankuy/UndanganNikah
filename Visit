<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Undangan Pernikahan Julian & Nuy</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Cinzel:wght@400;500&family=Jost:wght@300;400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #F5EDD8;
    --cream-light: #FBF6EC;
    --cream-mid: #EAD8B4;
    --gold: #B8932A;
    --gold-light: #D4AF5A;
    --brown: #6B4E2A;
    --brown-dark: #3D2B10;
    --text-muted: #8A6E4A;
  }

  html, body {
    width: 100%; height: 100%;
    background: var(--cream-light);
    overflow-x: hidden;
  }

  .cover {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--cream-light);
    overflow: hidden;
    padding: 60px 24px;
  }

  .cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 50% 0%, rgba(184,147,42,0.09) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 50% 100%, rgba(184,147,42,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Corner ornaments */
  .corner {
    position: absolute;
    width: 130px;
    height: 130px;
    opacity: 0.38;
  }
  .corner.tl { top: 16px; left: 16px; }
  .corner.tr { top: 16px; right: 16px; transform: scaleX(-1); }
  .corner.bl { bottom: 16px; left: 16px; transform: scaleY(-1); }
  .corner.br { bottom: 16px; right: 16px; transform: scale(-1,-1); }

  /* Inner border frame */
  .frame {
    position: absolute;
    inset: 28px;
    border: 0.5px solid rgba(184,147,42,0.22);
    pointer-events: none;
  }

  .cover-inner {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; align-items: center;
    text-align: center;
    animation: fadeUp 1.4s 0.2s ease both;
  }

  .invite-label {
    font-family: 'Cinzel', serif;
    font-size: 9.5px;
    letter-spacing: 6px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 22px;
  }

  .bismillah {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 15px;
    color: var(--text-muted);
    letter-spacing: 1px;
    margin-bottom: 30px;
    line-height: 1.8;
  }

  .divider {
    display: flex; align-items: center; gap: 14px;
    width: 100%; max-width: 300px;
    margin: 18px 0;
  }
  .divider::before, .divider::after {
    content: '';
    flex: 1;
    height: 0.5px;
    background: linear-gradient(to right, transparent, var(--gold-light), transparent);
  }
  .divider span { font-size: 16px; color: var(--gold); }

  .name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(56px, 13vw, 86px);
    color: var(--brown-dark);
    line-height: 1;
    letter-spacing: 3px;
  }

  .ampersand {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(38px, 9vw, 60px);
    color: var(--gold);
    display: block;
    line-height: 1.2;
    margin: 4px 0;
  }

  .tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 15px;
    color: var(--text-muted);
    letter-spacing: 1px;
    margin-top: 6px;
  }

  .date-line {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* Open button */
  .open-btn {
    margin-top: 34px;
    display: inline-flex;
    align-items: center; gap: 12px;
    padding: 15px 38px;
    border: 0.8px solid var(--gold-light);
    background: transparent;
    color: var(--brown);
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.4s ease, color 0.4s ease, border-color 0.4s ease;
  }
  .open-btn:hover {
    background: var(--gold);
    color: var(--cream-light);
    border-color: var(--gold);
  }
  .open-btn svg {
    width: 17px; height: 17px;
    transition: transform 0.4s ease;
  }
  .open-btn:hover svg { transform: translateY(2px); }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 22px;
    left: 50%; transform: translateX(-50%);
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--text-muted);
    text-transform: uppercase;
    opacity: 0.55;
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    white-space: nowrap;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 480px) {
    .corner { width: 80px; height: 80px; }
    .frame { inset: 18px; }
  }
</style>
</head>
<body>

<div class="cover">

  <!-- Thin inner frame -->
  <div class="frame"></div>

  <!-- Corner SVG ornaments -->
  <svg class="corner tl" viewBox="0 0 130 130" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M12,12 L12,90 Q12,118 40,118 L118,118" stroke="#B8932A" stroke-width="0.9" fill="none"/>
    <path d="M12,12 L12,55 Q12,76 33,76 L76,76" stroke="#B8932A" stroke-width="0.5" fill="none" opacity="0.45"/>
    <circle cx="12" cy="12" r="3.5" fill="#B8932A"/>
    <circle cx="118" cy="118" r="3.5" fill="#B8932A"/>
    <circle cx="76" cy="76" r="2" fill="#B8932A" opacity="0.5"/>
    <path d="M34,12 Q24,24 12,34" stroke="#B8932A" stroke-width="0.6" fill="none"/>
    <path d="M24,12 Q18,18 12,24" stroke="#B8932A" stroke-width="0.4" fill="none" opacity="0.4"/>
  </svg>
  <svg class="corner tr" viewBox="0 0 130 130" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M12,12 L12,90 Q12,118 40,118 L118,118" stroke="#B8932A" stroke-width="0.9" fill="none"/>
    <path d="M12,12 L12,55 Q12,76 33,76 L76,76" stroke="#B8932A" stroke-width="0.5" fill="none" opacity="0.45"/>
    <circle cx="12" cy="12" r="3.5" fill="#B8932A"/>
    <circle cx="118" cy="118" r="3.5" fill="#B8932A"/>
    <path d="M34,12 Q24,24 12,34" stroke="#B8932A" stroke-width="0.6" fill="none"/>
    <path d="M24,12 Q18,18 12,24" stroke="#B8932A" stroke-width="0.4" fill="none" opacity="0.4"/>
  </svg>
  <svg class="corner bl" viewBox="0 0 130 130" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M12,12 L12,90 Q12,118 40,118 L118,118" stroke="#B8932A" stroke-width="0.9" fill="none"/>
    <circle cx="12" cy="12" r="3.5" fill="#B8932A"/>
    <circle cx="118" cy="118" r="3.5" fill="#B8932A"/>
    <path d="M34,12 Q24,24 12,34" stroke="#B8932A" stroke-width="0.6" fill="none"/>
  </svg>
  <svg class="corner br" viewBox="0 0 130 130" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M12,12 L12,90 Q12,118 40,118 L118,118" stroke="#B8932A" stroke-width="0.9" fill="none"/>
    <circle cx="12" cy="12" r="3.5" fill="#B8932A"/>
    <circle cx="118" cy="118" r="3.5" fill="#B8932A"/>
    <path d="M34,12 Q24,24 12,34" stroke="#B8932A" stroke-width="0.6" fill="none"/>
  </svg>

  <!-- Content -->
  <div class="cover-inner">
    <p class="invite-label">Undangan Pernikahan</p>

    <p class="bismillah">بِسْمِ اللهِ الرَّحْمٰنِ الرَّحِيْمِ</p>

    <div class="name">Julian</div>
    <div class="ampersand">&amp;</div>
    <div class="name">Nuy</div>

    <p class="tagline">dalam hari bahagia kami</p>

    <div class="divider"><span>✦</span></div>

    <!-- Ganti dengan tanggal asli jika perlu -->
    <p class="date-line">00 · Bulan · 2025</p>

    <!-- TOMBOL BUKA UNDANGAN -->
    <!-- Ganti href="#" dengan link undangan lengkap kamu -->
    <a href="https://undangankuy.github.io/UndanganNikah/undangan.html#" class="open-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
        <path d="M3 8l9 6 9-6M3 8v10a1 1 0 001 1h16a1 1 0 001-1V8M3 8l9-5 9 5"/>
      </svg>
      Buka Undangan
    </a>
  </div>

  <p class="scroll-hint">klik untuk membuka undangan</p>
</div>

</body>
</html>
